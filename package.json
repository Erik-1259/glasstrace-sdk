{
  "name": "glasstrace-sdk",
  "private": true,
  "description": "Glasstrace SDK monorepo — server-side debugging for AI coding agents",
  "author": "Glasstrace <hello@glasstrace.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Erik-1259/glasstrace-sdk"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.6.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "vitest run",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "check:no-internal-ids": "node scripts/check-no-internal-ids.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.9.2",
    "eslint": "^10.5.0",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
